---
const modes = [
  {
    label: "Local Vault",
    analogy: "The Git model",
    desc: "One binary. Initialize in any directory. Your markdown files become searchable memories. A background daemon shares the model across all vaults.",
    code: `hebbs init\nhebbs index\nhebbs recall "auth token rotation"\nhebbs panel    # open Memory Palace`,
    lang: "bash",
  },
  {
    label: "Standalone Server",
    analogy: "The Redis model",
    desc: "Multi-tenant gRPC + HTTP server for production agent fleets. Connect from Python, TypeScript, or the CLI.",
    code: `hebbs-server --port 6380 --data ./hebbs-data`,
    lang: "bash",
  },
  {
    label: "Edge Mode",
    analogy: "Robots, laptops, workstations",
    desc: "Full engine on-device. Local ONNX embeddings. Local LLM for reflect. Autonomous offline operation.",
    code: `[engine]\nmode = "edge"\n\n[reflect]\nllm_provider = "local"\nllm_model = "phi-3-mini"\n\n[sync]\nhub = "wss://fleet.example.com/hebbs"\ninterval = "30s"`,
    lang: "toml",
  },
];
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Same engine. Local, server, or edge.
      </h2>
      <p class="text-muted text-lg">
        One binary. Three deployment modes. The cognitive engine is identical everywhere.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {modes.map((mode) => (
        <div class="rounded-xl border border-border bg-surface/40 p-6 flex flex-col">
          <div class="mb-4">
            <h3 class="text-text font-semibold mb-1">{mode.label}</h3>
            <p class="font-mono text-xs text-accent">{mode.analogy}</p>
          </div>
          <p class="text-sm text-muted leading-relaxed mb-5 flex-1">{mode.desc}</p>
          <div class="rounded-lg bg-bg border border-border p-4 overflow-x-auto">
            <pre class="font-mono text-xs text-muted leading-relaxed whitespace-pre">{mode.code}</pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
